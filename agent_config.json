{
  "timezone_offset_hours": 8,
  "paths": {
    "runs_root": "runs",
    "state_root": "state",
    "knowledge_root": "knowledge",
    "decision_log": "state/decision_log.jsonl",
    "step1_csv": "candidates.csv",
    "step2_csv": "candidates_step2.csv"
  },
  "schedule": {
    "preopen": "08:30",
    "intraday": "12:30",
    "postclose": "20:30"
  },
  "postclose": {
    "max_candidates_for_research": 8,
    "max_new_positions": 3,
    "default_transaction_cost_rate": 0.0015
  },
  "gates": {
    "min_evidence_completeness": 0.6,
    "min_action_delta": 0.02,
    "max_allowed_constraint_violations": 0
  },
  "constraints": {
    "max_single_weight": 0.3,
    "max_industry_weight": 0.5,
    "min_cash_ratio": 0.1
  },
  "alerts": {
    "intraday_loss_alert_pct": -5.0,
    "intraday_profit_alert_pct": 8.0
  },
  "execution": {
    "slippage_bps": 5.0,
    "commission_rate": 0.0003,
    "stamp_duty_sell_rate": 0.001,
    "max_cost_ratio_total_asset": 0.005,
    "enforce_constraint_guard": true,
    "constraint_tolerance": 0.001,
    "manual_only": true
  },
  "maintenance": {
    "review_stale_hours": 24.0,
    "execution_stale_hours": 24.0,
    "retain_days": 14.0
  },
  "feedback": {
    "quality_window_days": 30,
    "default_min_confidence_buy": 0.6
  },
  "skill_promotion": {
    "min_occurrences": 3,
    "quality_threshold": 0.62,
    "promote_delta": 0.08,
    "owner": "auto_agent"
  },
  "ops_alerts": {
    "health_score_warn": 80.0,
    "health_score_critical": 70.0,
    "stale_review_warn": 1,
    "stale_execution_warn": 1,
    "oldest_review_hours_warn": 24.0,
    "oldest_review_hours_critical": 48.0,
    "oldest_execution_hours_warn": 24.0,
    "oldest_execution_hours_critical": 48.0,
    "quality_score_warn": 0.6,
    "quality_score_critical": 0.5,
    "quality_min_sample_size": 3,
    "feedback_min_confidence_warn": 0.78,
    "report_stale_hours_warn": 8.0,
    "report_stale_hours_critical": 24.0,
    "reminder_hours": 24.0
  },
  "action_center": {
    "max_review_items": 8,
    "max_execution_items": 8,
    "max_alerts": 8
  },
  "notifications": {
    "enabled": true,
    "send_events": "opened,escalated,resolved",
    "send_levels": "warn,critical",
    "cooldown_minutes": 30,
    "max_events": 200,
    "ntfy": {
      "enabled": true,
      "base_url": "https://ntfy.sh",
      "topic": "invest-zdu881",
      "timeout_sec": 8.0
    }
  },
  "llm": {
    "enabled": true,
    "provider": "siliconflow",
    "base_url": "https://api.siliconflow.cn/v1/chat/completions",
    "model": "Pro/zai-org/GLM-5",
    "timeout_sec": 45.0,
    "temperature": 0.2,
    "max_tokens": 320,
    "api_key_env": "SILICONFLOW_API_KEY",
    "env_file": ".env.local"
  },
  "pdf_ingest": {
    "enabled": true,
    "provider": "none",
    "complex_only": true,
    "cache_root": "knowledge/documents",
    "simple_preview_pages": 6,
    "simple_max_chars": 12000,
    "complex_page_threshold": 12,
    "low_text_chars_per_page": 120,
    "large_file_bytes": 10485760,
    "image_block_threshold": 3,
    "mineru_cmd": "mineru",
    "mineru_method": "auto",
    "mineru_lang": "ch",
    "mineru_timeout_sec": 300,
    "mineru_backend": "pipeline"
  }
}
